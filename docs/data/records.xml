    <body>
      <listEvent>
        <event xml:id="ev-1598-06-20" when="1598-06-20" corresp="#place-york-guildhall">
          <head>Payment for pageant costumes</head>
          <p>
            Item, paid to <name type="person" ref="#person-margaret-hall">Margaret Hall</name>
            for mending garments for players before midsummer.
          </p>
        </event>

        <event xml:id="ev-1601-04-12" when="1601-04-12" corresp="#place-ouse-bridge">
          <head>Order concerning procession route</head>
          <p>
            The council directs <name type="person" ref="#person-richard-bentley">Richard Bentley</name>
            to supervise banners along the bridge and market approach.
          </p>
        </event>
      </listEvent>
    </body>
